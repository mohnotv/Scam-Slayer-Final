# ScamSlayer environment variables
# Copy this file to .env and fill in real values. NEVER commit .env.

# LLM provider for the Dialogue Agent (when MOCK_CLAUDE=false)
# Supported: anthropic | gemini
LLM_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=your_gemini_api_key
# Best quality:
GEMINI_MODEL=gemini-2.5-pro-latest

# Anthropic (only needed if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Twilio — Voice + Media Streams. Get from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Deepgram — streaming STT (Nova-3 model)
DEEPGRAM_API_KEY=your_deepgram_api_key

# ElevenLabs — TTS for persona voices
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# SQLite (dev) or PostgreSQL URL (prod: postgresql+asyncpg://user:pass@host/db)
DATABASE_URL=sqlite+aiosqlite:///./scamslayer.db

# Redis — arq background job queue
REDIS_URL=redis://localhost:6379/0

# ngrok public URL so Twilio can reach your local FastAPI (run `ngrok http 8000`)
NGROK_URL=https://xxxx.ngrok-free.app

# Live-call mode:
#   gather = Twilio speech recognition (no Deepgram required)
#   stream = Twilio Media Streams (Deepgram integration TODO in this repo)
VOICE_MODE=gather

# When true, Twilio records the full call; after hang-up, open the call in the dashboard and use the audio player.
# Requires a real NGROK_URL (not placeholder). Set false to skip recording.
RECORD_VOICE_CALLS=true

# Agent toggles — set to false to use the real external API
# Dialogue agent: false = call hosted LLM (LLM_PROVIDER + corresponding API key)
MOCK_CLAUDE=true
