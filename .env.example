# ScamSlayer environment variables
# Copy this file to .env and fill in real values. NEVER commit .env.

# Anthropic Claude — used by the Dialogue Agent (claude-sonnet-4-5)
ANTHROPIC_API_KEY=sk-ant-...

# Twilio — Voice + Media Streams. Get from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Deepgram — streaming STT (Nova-3 model)
DEEPGRAM_API_KEY=your_deepgram_api_key

# ElevenLabs — TTS for persona voices
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# SQLite (dev) or PostgreSQL URL (prod: postgresql+asyncpg://user:pass@host/db)
DATABASE_URL=sqlite+aiosqlite:///./scamslayer.db

# Redis — arq background job queue
REDIS_URL=redis://localhost:6379/0

# ngrok public URL so Twilio can reach your local FastAPI (run `ngrok http 8000`)
NGROK_URL=https://xxxx.ngrok-free.app
